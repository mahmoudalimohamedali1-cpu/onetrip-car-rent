# ===========================================================================
# One Trip — WhatsApp Bridge environment (انسخ هذا الملف إلى .env)
# ===========================================================================

# توكن التحقّق من Meta webhook — اختره أنت (أي نص سرّي) وضعه نفسه في لوحة Meta.
WA_VERIFY_TOKEN=change-me-verify-token

# توكن واتساب الدائم (Permanent Access Token) من تطبيق Meta / System User.
# سرّي — لا تشاركه أبدًا.
WA_TOKEN=EAAG...your-permanent-token

# معرّف رقم الهاتف (Phone Number ID) من WhatsApp > API Setup (ليس الرقم نفسه).
WA_PHONE_NUMBER_ID=1234567890

# منفذ السيرفر (المنصّات السحابية تضبطه تلقائيًا غالبًا).
PORT=3000

# نسخة Graph API (اختياري).
# WA_GRAPH_VERSION=v19.0

# ---------------------------------------------------------------------------
# اختياري: وضع Supabase (Supabase mode)
# لو ضُبط المتغيّران التاليان ⇒ يكتب الجسر إلى نفس جداول conversations + messages
# المشتركة مع الموقع، فيظهر الوارد من واتساب فورًا في الودجة واللوحة (Realtime).
# لو تُركا فارغين ⇒ يستخدم store.json محليًا (السلوك الافتراضي).
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
#
# تنبيه أمني: SUPABASE_SERVICE_KEY هو مفتاح service_role — سرّي وعلى السيرفر فقط.
# لا تضعه أبدًا في كود الواجهة أو في مستودع عام.
# SUPABASE_SERVICE_KEY=your-service-role-key
